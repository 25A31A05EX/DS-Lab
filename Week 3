4.Write a cpp code to identify no.of occurences of a search key using linear search or sequential search
#include <iostream>
using namespace std;
int main(){
int n,i,key,count=0;
cout<<"Enter size  of an array and key element";
cin>>n>>key;
int a[n];
cout<<"Enter array elements";
for(i=0;i<n;i++)
{
cin>>a[i];
if(a[i] == key){
cout<<"Search element found at "<<i+1<<location";
count++;
}
}
if(count==0)
cout<<key<<" element is not found";
else
cout<<"Key element found<<count<<" times";
return 0;
}

5.Write a c++ code to implement binary search
#include <iostream>
using namespace std;
int main(){
int n,i,key,mid;
bool status = 0;
cout<<"Enter size  of an array and key element";
cin>>n>>key;
int a[n],low=0,high=n-1;
cout<<"Enter array elements";
for(i=0;i<n;i++)
cin>>a[i];
while(low<=high)
{
mid=(low+high)/2;
if(a[mid]==key)
{
cout<<key<<" element found at "<<mid<<" location";
status=true;
break;
}
else if(a[mid]<key)
low=mid+1;
else
high=mid-1;
}
if(!status)
cout<<key<<" element not found";
return 0;
}

