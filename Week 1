5)write a c++ program to find factorial of a number 
#include<iostream>
using namespace std;
int main() { 
int number; long long factorial = 1; 
cout << "Enter a non-negative integer: ";
cin >> number;
if (number < 0) {
    std::cout << "Factorial is not defined for negative numbers." << std::endl;
} else {
    for (int i = 1; i <= number; ++i) {
        factorial *= i;
    }
    std::cout << "Factorial of " << number << " = " << factorial << std::endl;
}
return 0;
}

